PORT=3000

# MongoDB connection string (Atlas free tier or local mongod)
MONGODB_URI=

# Firebase Admin SDK service account — paste the entire JSON as a single-line string
# Source: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=

# Firebase Storage bucket name (e.g. <project-id>.appspot.com)
# Source: Firebase Console -> Storage -> bucket name
FIREBASE_STORAGE_BUCKET=

# Admin panel credentials (reserved for Plan 04 — admin approval workflow)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=

# Socket.io CORS allowed origins — comma-separated list (T-02-01-03)
# Production: set to your backend domain (e.g. https://api.womenapp.com)
# Development default: http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
