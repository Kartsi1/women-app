# Firebase Web App Config
# Obtain from: Firebase Console -> Project Settings -> General -> Your apps -> Web app config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Backend base URL reachable from the device/emulator
# Android emulator: http://10.0.2.2:3000
# iOS simulator:    http://localhost:3000
# Physical device:  http://<your-local-ip>:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Google Maps API key — required for map rendering in EAS builds (plan 02-01)
# Source: Google Cloud Console -> APIs & Services -> Credentials -> Create API key
#         Enable: Maps SDK for Android; restrict to your Android package name
# Note: EXPO_PUBLIC_* vars are embedded in the client bundle (not secret).
#       Restrict the key in Google Cloud Console instead of keeping it out of source.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
